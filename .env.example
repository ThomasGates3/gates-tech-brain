# ── AI Brain — environment ─────────────────────────────────────────────
# Copy to .env.local (gitignored) and fill in. Never commit real secrets.

# AI Gateway (Vercel) — REQUIRED to bring the brain online.
# Get one at https://vercel.com/dashboard → AI Gateway, or use an OIDC token on Vercel.
AI_GATEWAY_API_KEY=

# Runtime model tier: "standard" (Sonnet, cheaper) or "flagship" (Opus, premium)
MODEL_TIER=standard

# Which vertical persona to run: agency | accounting | law | medical | insurance
VERTICAL=agency

# Neon Postgres (serverless) — for jobs, knowledge (pgvector), audit, approvals.
# Local dev works without it; needed for persistence.
DATABASE_URL=

# Security — password gate. Set ACCESS_PASSWORD to lock the whole app behind a
# single password (login at /sign-in). The gate turns on automatically once set.
# AUTH_SECRET signs the session cookie — REQUIRED in prod. openssl rand -base64 32
ACCESS_PASSWORD=
AUTH_SECRET=

# Optional: comma-separated allowed origins in production (CORS)
CORS_ORIGINS=

# Chat delivery — automations post their results here. Set EITHER (or both);
# each is a free webhook. Discord is easiest on mobile:
#   Discord: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
#   Slack:   https://api.slack.com/messaging/webhooks
DISCORD_WEBHOOK_URL=
SLACK_WEBHOOK_URL=

# Cron protection — Vercel Cron sends this as a Bearer token to /api/cron
CRON_SECRET=

# Connector credentials (vault keys) — one per connector you enable, e.g.:
# GITHUB_TOKEN=
# VERCEL_TOKEN=

# ── Business app connectors ─────────────────────────────────────────────
# For each app: URL = where it's reachable (deployed or localhost), TOKEN =
# the agent access token you add to that app's API so the Brain can call it.
TWIN_TRADING_URL=
TWIN_TRADING_TOKEN=
TWIN_TRADING_BIO_URL=
TWIN_TRADING_BIO_TOKEN=
AD_SYSTEM_URL=
AD_SYSTEM_TOKEN=
AI_LINK_BIO_URL=
AI_LINK_BIO_TOKEN=
GATES_TECH_URL=
GATES_TECH_TOKEN=
SPEED_TO_LEAD_URL=
SPEED_TO_LEAD_TOKEN=

# ── Moby dev-agent ──────────────────────────────────────────────────────
# The Brain spins up a coding agent (Claude Code) on the Moby repo.
MOBY_REPO_PATH=/Users/tg3/dev/moby
MOBY_DEV_ENABLED=false   # set true to let agents actually run (edits on a branch)
# CLAUDE_BIN=claude      # override if the CLI isn't on PATH
